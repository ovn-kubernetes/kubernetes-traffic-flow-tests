apiVersion: v1
kind: Service
metadata:
  name: tft-nodeport-service-{{ svc_label }}
  namespace: {{ name_space }}
  labels:
    tft-tests: {{ label_tft_tests }}
spec:
  type: NodePort
  ports:
    - name: tft-nodeport-service-tcp-{{ port }}
      protocol: TCP
      port: {{ port }}
    - name: tft-nodeport-service-udp-{{ port }}
      protocol: UDP
      port: {{ port }}
  selector:
    tft-pod-name: {{ pod_name }}
