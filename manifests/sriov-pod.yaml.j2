apiVersion: v1
kind: Pod
metadata:
  namespace: {{ name_space }}
  name: {{ pod_name }}
  annotations: {% if not use_secondary_network %}
    v1.multus-cni.io/default-network: {{ default_network }} {% else %}
    k8s.v1.cni.cncf.io/networks: {{ secondary_network_nad }} {% endif %}
  labels:
    tft-tests: {{ label_tft_tests }}
    tft-port: "{{ port }}"
    tft-network: primary
spec:
  nodeSelector:
    kubernetes.io/hostname: {{ node_name }}
  tolerations:
  - key: "node.kubernetes.io/unschedulable"
    effect: "NoSchedule"
    operator: "Exists"
  containers:
  - name: tft
    image: {{ test_image }}
    command: {{ command }}
    args: {{ args }}
    imagePullPolicy: {{ image_pull_policy }}{% if has_resource_name or has_resources %}
    resources:
      requests: {% if has_resource_name %}
        {{ resource_name }}: '1'{% endif %}{% if cpu_request %}
        cpu: {{ cpu_request }}{% endif %}{% if mem_request %}
        memory: {{ mem_request }}{% endif %}
      limits: {% if has_resource_name %}
        {{ resource_name }}: '1'{% endif %}{% if cpu_limit %}
        cpu: {{ cpu_limit }}{% endif %}{% if mem_limit %}
        memory: {{ mem_limit }}{% endif %}{% endif %}
    securityContext:
      privileged: {{ privileged_pod }}
      capabilities: {{ capabilities_pod }}
