apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  namespace: {{ name_space }}
  name: {{ np_allow_name }}
  labels:
    tft-tests: {{ label_tft_tests }}
spec:
  podSelector:
    matchLabels:
      tft-tests: {{ label_tft_tests }}
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: {{ np_ns_name }}
      ports:
        - port: {{ np_ns_port }}
          protocol: TCP
